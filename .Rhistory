ggplot(aes(x=temperature,y=count, color=migration_level, size=amt))+
geom_point()+
geom_smooth(method=lm, color="black")+
theme_tufte()+
scale_fill_manual(values=my_palette[3:10])+ ##first two colors were too light for a scatterplot, so i removed them here
scale_color_manual(values=my_palette[3:10])+
labs(y="Number of collisions (log10)",x="Temperature (ºC)", title="Temperature compared to collision count in fall, sized by migration level", color="Migration level")+
scale_y_log10()+
theme(legend.position = "none")
