knitr::opts_chunk$set(echo = TRUE)
library(tidyverse)
library(janitor)
library(naniar)
bird_collision <- read.csv("data/bird_collision.csv")
summary(bird_collision)
glimpse(bird_collision)
glimpse(bird_collision)
glimpse(bird_collision)
bird_collision <- read.csv("data/bird_collision.csv")  %>% clean_names()
glimpse(bird_collision)
miss_var_summary(bird_collision)
bird_collision %>%
distinct(year)
bird_collision %>%
distinct(year) #there's 2017 to 2020
bird_collision %>%
seperate(col="date", into=c("month", "day", "year"), sep = "/")
bird_collision %>%
separate(col="date", into=c("month", "day", "year"), sep = "/")
bird_collision %>%
separate(col="date", into=c("month", "day", "year"), sep = "/") %>%
select(year, month, count)
bird_collision %>%
separate(col="date", into=c("month", "day", "year"), sep = "/") %>%
select(year, month, count) %>%
mutate(month=as.factor(month)) %>%
group_by(year, month) %>%
summarize(monthly_collision = sum(count))
bird_collision %>%
separate(col="date", into=c("month", "day", "year"), sep = "/") %>%
select(year, month, count) %>%
mutate(month=as.factor(month)) %>%
group_by(year, month) %>%
summarize(monthly_collision = sum(count)) %>%
ggplot(aes(x = month, y = monthly_collision)) +
geom_col(fill = monthly_collision) +
facet_grid(~year) +
labs ( title = "Monthly Bird Collisions by year", x = "Month", y = "Total Collisions") +
theme_classic()
